@import "tailwindcss";
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

:root {
  --color-primary: #007BFF; /* B5 Blue */
  --color-secondary: #A4FF00; /* Lime Green */
  --color-background: #0A0F2C;
  --color-surface: #121A3A;
  --color-text-primary: #F5F7FA;
  --color-text-secondary: #9AA4B2;
  --color-border: #2A3A6A;
  --color-success: #66FF00;
  --color-error: #FF3B30;
  --color-warning: #FFCC00;
}

@theme inline {
  --color-primary: var(--color-primary);
  --color-secondary: var(--color-secondary);
  --color-background: var(--color-background);
  --color-surface: var(--color-surface);
  --color-text-primary: var(--color-text-primary);
  --color-text-secondary: var(--color-text-secondary);
  --color-border: var(--color-border);
  --color-success: var(--color-success);
  --color-error: var(--color-error);
  --color-warning: var(--color-warning);
}

body {
  background-color: var(--color-background);
  color: var(--color-text-primary);
  font-family: "Poppins", sans-serif;
  margin: 0;
  padding: 0;
}

.app-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
  min-height: 100vh;
}

header {
  text-align: center;
  margin-bottom: 40px;
}

h1 {
  color: var(--color-primary);
  font-size: 2.5rem;
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.subtitle {
  color: var(--color-text-secondary);
  font-size: 1.1rem;
}

nav {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 30px;
}

.tab-button {
  background: var(--color-surface);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
  padding: 10px 25px;
  border-radius: 30px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 500;
}

.tab-button.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  border-color: transparent;
  color: #000;
}

.summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  margin-bottom: 40px;
}

.summary-card {
  background: var(--color-surface);
  padding: 25px;
  border-radius: 15px;
  border: 1px solid var(--color-border);
  text-align: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.summary-card h3 {
  margin: 0 0 10px 0;
  color: var(--color-text-secondary);
  font-size: 1rem;
  text-transform: uppercase;
}

.summary-card p {
  margin: 0;
  font-size: 2rem;
  font-weight: 700;
}

.income-amount { color: var(--color-success); }
.expense-amount { color: var(--color-error); }
.balance-amount { color: var(--color-primary); }

.card {
  background: var(--color-surface);
  padding: 30px;
  border-radius: 15px;
  border: 1px solid var(--color-border);
  margin-bottom: 30px;
}

h2 {
  margin-top: 0;
  margin-bottom: 25px;
  font-size: 1.5rem;
  border-left: 4px solid var(--color-secondary);
  padding-left: 15px;
}

form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

input, select {
  background: var(--color-background);
  border: 1px solid var(--color-border);
  color: var(--color-text-primary);
  padding: 12px;
  border-radius: 8px;
  outline: none;
  font-size: 1rem;
}

input:focus, select:focus {
  border-color: var(--color-primary);
}

button.primary {
  grid-column: span 2;
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  color: #000;
  border: none;
  padding: 14px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  font-size: 1rem;
}

button.primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 15px rgba(0, 123, 255, 0.4);
}

.filters {
  display: flex;
  gap: 15px;
  margin-bottom: 20px;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  padding: 15px;
  text-align: left;
  border-bottom: 1px solid var(--color-border);
}

th {
  color: var(--color-text-secondary);
  font-weight: 500;
  text-transform: uppercase;
  font-size: 0.85rem;
}

tr:hover {
  background: rgba(255, 255, 255, 0.03);
}

.chart-container {
  height: 400px;
  margin-top: 20px;
}

.delete-btn {
  background: transparent;
  color: var(--color-error);
  border: none;
  cursor: pointer;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.delete-btn:hover {
  opacity: 1;
}

.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: calc(100vh - 40px);
}

.auth-card {
  width: 100%;
  max-width: 400px;
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 20px;
}

.input-group {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 12px;
  color: var(--color-text-secondary);
}

.input-group input {
  padding-left: 40px;
  width: 100%;
}

.error-message {
  background: rgba(255, 59, 48, 0.1);
  color: var(--color-error);
  padding: 10px;
  border-radius: 8px;
  margin-bottom: 15px;
  font-size: 0.9rem;
  text-align: center;
  border: 1px solid var(--color-error);
  overflow: hidden;
}

.success-message {
  background: rgba(102, 255, 0, 0.1);
  color: var(--color-success);
  padding: 10px;
  border-radius: 8px;
  margin-bottom: 15px;
  font-size: 0.9rem;
  text-align: center;
  border: 1px solid var(--color-success);
  overflow: hidden;
}

.auth-footer {
  margin-top: 20px;
  text-align: center;
  color: var(--color-text-secondary);
}

.text-link {
  background: none;
  border: none;
  color: var(--color-primary);
  cursor: pointer;
  font-weight: 600;
  padding: 0;
  font-size: 1rem;
}

.text-link:hover {
  text-decoration: underline;
}

.header-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 15px;
}

.user-profile {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.05);
  padding: 6px 12px;
  border-radius: 20px;
  border: 1px solid var(--color-border);
}

.user-icon {
  color: var(--color-secondary);
}

.logout-btn {
  background: rgba(255, 255, 255, 0.05);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
  padding: 6px 15px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 0.85rem;
  transition: all 0.2s;
  display: flex;
  align-items: center;
}

.logout-btn:hover {
  background: var(--color-error);
  color: white;
  border-color: var(--color-error);
}

@media (max-width: 768px) {
  form {
    grid-template-columns: 1fr;
  }
  button.primary {
    grid-column: span 1;
  }
  .nav {
    flex-wrap: wrap;
    gap: 10px;
  }
  .tab-button {
    padding: 8px 15px;
    font-size: 0.9rem;
    flex: 1 1 auto;
    text-align: center;
  }
  .filters {
    flex-direction: column;
  }
  table {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
  }
  h1 {
    font-size: 1.8rem;
  }
}
